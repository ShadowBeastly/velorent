# Copy this file to `.env.local` and fill in the values.

# Public runtime
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_SITE_URL=https://lociva.de
NEXT_PUBLIC_DEMO_EMAIL=demo@example.com
NEXT_PUBLIC_DEMO_PASSWORD=demo-password

# Server-only runtime
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
INTERNAL_FUNCTION_SECRET=change-me
DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=demo-password

# Optional app configuration
NEXT_PUBLIC_STRIPE_PRICE_ID=
NEXT_PUBLIC_APP_URL=https://rentcore.de

# Email / Edge Function secrets
# Configure these in Supabase secrets for Edge Functions.
# BREVO_API_KEY=
# FROM_EMAIL=noreply@lociva.de
# FROM_NAME=Lociva
