# =====================================================
# VELORENT PRO - ENVIRONMENT VARIABLES
# =====================================================
# Kopiere diese Datei nach .env und fülle die Werte aus
# =====================================================

# SUPABASE (PFLICHT)
# Aus: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# APP URL (für E-Mail Links)
VITE_APP_URL=https://velorent.de

# STRIPE (Optional - erst wenn du Payments brauchst)
# Aus: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_YEARLY_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...

# RESEND (Optional - für E-Mails)
# Aus: https://resend.com/api-keys
RESEND_API_KEY=re_...
