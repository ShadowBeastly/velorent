# =====================================================
# LOCIVA / RENTCORE - ENVIRONMENT VARIABLES
# =====================================================
# Copy this file to .env.local and fill in the values
# =====================================================

# SUPABASE (required)
# From: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# STRIPE (required for payments)
# From: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Server-only keys (NEVER prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# BREVO / EMAIL (required for booking confirmations)
# Set as Supabase Edge Function Secrets: supabase secrets set KEY=value
# BREVO_API_KEY=
# FROM_EMAIL=noreply@lociva.de
# FROM_NAME=Lociva
